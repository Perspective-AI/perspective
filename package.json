{
  "name": "perspective-embed",
  "private": true,
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "postinstall": "lefthook install",
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "oxlint --fix",
    "lint:check": "oxlint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:watch": "turbo test -- --watch",
    "test:coverage": "turbo test -- --coverage",
    "test:ssr": "turbo test:ssr",
    "test:types": "attw --pack packages/sdk --ignore-rules=no-resolution && attw --pack packages/sdk-react --ignore-rules=no-resolution",
    "test:e2e": "turbo test:e2e",
    "test:e2e:ui": "pnpm --filter @perspective/sdk exec playwright test --ui",
    "check": "pnpm lint:check && pnpm format:check && pnpm typecheck",
    "changeset": "changeset",
    "version": "changeset version && pnpm install --lockfile-only",
    "release": "turbo build && changeset publish"
  },
  "pnpm": {
    "overrides": {
      "picomatch@<2.3.2": "^2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "^4.0.4",
      "rollup@>=4.0.0 <4.59.0": "^4.59.0",
      "fast-uri@<3.1.2": "^3.1.2",
      "js-yaml@>=4.0.0 <4.2.0": "^4.2.0",
      "read-yaml-file@1.1.0": "^2.1.0"
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@changesets/cli": "^2.30.0",
    "@playwright/test": "^1.60.0",
    "@vitest/coverage-v8": "^4.1.9",
    "happy-dom": "^20.8.9",
    "lefthook": "^2.0.15",
    "oxlint": "^1.0.0",
    "prettier": "^3.5.0",
    "serve": "^14.2.6",
    "turbo": "^2.10.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.5",
    "vitest": "^4.1.9"
  }
}
