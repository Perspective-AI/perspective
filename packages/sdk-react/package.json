{
  "name": "@perspective-ai/sdk-react",
  "version": "1.6.1",
  "description": "React components for Perspective AI embed SDK",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "perspective",
    "perspective-ai",
    "embed",
    "sdk",
    "react",
    "ai",
    "llm",
    "conversational-ai",
    "research",
    "interview",
    "voice-agent",
    "widget"
  ],
  "author": "Perspective AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Perspective-AI/perspective.git",
    "directory": "packages/sdk-react"
  },
  "bugs": {
    "url": "https://github.com/Perspective-AI/perspective/issues"
  },
  "homepage": "https://getperspective.ai",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@perspective-ai/sdk": "workspace:^"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.1",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
